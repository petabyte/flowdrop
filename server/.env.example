# Cloudflare R2 Credentials
# Get these from: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name

# Public URL for your R2 bucket
# Enable "Public Access" on the bucket to get this URL
# Format: https://pub-<hash>.r2.dev  OR  https://cdn.yourdomain.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# API Keys per subscription tier
# Generate strong random strings: openssl rand -hex 32
# The tier is resolved at upload time from whichever key the client sends.
FREE_API_KEY=your_free_tier_api_key
STARTER_API_KEY=your_starter_tier_api_key
PRO_API_KEY=your_pro_tier_api_key
# Generic fallback (treated as free tier)
API_KEY_SECRET=your_generic_api_key_here

# Server config
PORT=3000

# Cleanup cron schedule (default: 2:00 AM daily)
# Use standard cron syntax. Examples:
#   '0 2 * * *'     → 2:00 AM daily
#   '0 * * * *'     → top of every hour
#   '*/5 * * * *'   → every 5 minutes (testing only)
CLEANUP_CRON=0 2 * * *

# SQLite DB is stored in ./data/uploads.db (auto-created, add to .gitignore)

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://yourdomain.com
